(def-method :fixed :lisp_recip)
	;inputs
	;:r0 = lisp object (ptr)
	;:r1 = args list object (ptr)
	;outputs
	;:r0 = lisp object (ptr)
	;:r1 = return value object (ptr)
	;trashes
	;:r1-:r7, :r14, :f0-:f15

	(entry :fixed :lisp_recip '(:r0 :r1))

	(errorif-lisp-args-sig 'error :r1 1)

	(vp-push :r0)
	(assign '((:r1 +array_begin)) '(:r0))
	(assign '((:r0 0)) '(:r0))

(errorcase
	(assign '((:r0 +num_value)) '(:r2))
	(gotoif '(:r2 = 0) 'error1))

	(call :fixed :recip '(:r0) '(:r1))
	(vp-pop :r0)

	(exit :fixed :lisp_recip '(:r0 :r1))
	(vp-ret)

(errorcase
(vp-label 'error1)
	(vp-pop :r0)
(vp-label 'error)
	(jump :lisp :repl_error '(:r0 :r1 "(recip fixed)" +error_msg_wrong_types))
	(signature '(:fixed)))

(def-func-end)
