(include "lib/asm/func.inc")
(include "./class.inc")
(include "././lisp/class.inc")

;generic fixed math op
(redefun mathop (%0)
	(entry :fixed (sym (cat :lisp_ (rest %0))) '(:r0 :r1))
	(errorif-lisp-args-sig 'error :r1 1)
	(vp-cpy-rr :r0 :r13)
	(assign '((:r1 +array_begin)) '(:r2))
	(call :fixed %0 '((:r2 0)) '(:r1))
	(exit :fixed (sym (cat :lisp_ (rest %0))) '(:r13 :r1))
	(vp-ret))

(def-method :fixed :lisp_sin)
	;inputs
	;:r0 = lisp object (ptr)
	;:r1 = args list object (ptr)
	;outputs
	;:r0 = lisp object (ptr)
	;:r1 = return value object (ptr)
	;trashes
	;:r1-:r7, :r13-:r14, :f0-:f15

	(mathop :sin)

(errorcase
(vp-label 'error)
	(jump :lisp :repl_error '(:r0 :r1 "(sin fixed)" +error_msg_wrong_types))
	(signature '(:fixed)))

(def-func-end)

